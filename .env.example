NEXT_PUBLIC_WALLET_CONNECT_ID=12345678901234567890123456789012
NEXT_PUBLIC_RPC_OVERRIDES='{"chain1":{"http":"https://..."}}'
NEXT_PUBLIC_BRIDGE_DASHBOARD_URL=https://bridge-dashboard.testnet.pruv.network/

# Bridge & Swap widget (LI.FI).
# Override the Jumper proxy base path; defaults to the in-app Next.js proxy at /api/jumper.
NEXT_PUBLIC_JUMPER_API_URL=/api/jumper
# Integrator ID reported to LI.FI when the user picks "LI.FI direct" mode.
NEXT_PUBLIC_LIFI_INTEGRATOR=bridge-swap-widget